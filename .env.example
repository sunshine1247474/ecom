# ─────────────────────────────────────────────────────────────────────────────
# Resale Scanner — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to Git — it is already in .gitignore.
#
# In GitHub Codespaces, set these as Codespaces Secrets instead:
#   Repository Settings → Secrets and variables → Codespaces
# ─────────────────────────────────────────────────────────────────────────────


# ── Traject Data APIs (trajectdata.com) ───────────────────────────────────────
# All plans start at $15/month. Free trials available.
# Sign up at https://trajectdata.com — each API has its own key.

# Amazon product data — https://www.rainforestapi.com/
RAINFOREST_API_KEY=

# Walmart product data — https://app.bluecartapi.com/
BLUECART_API_KEY=

# Target product data — https://app.redcircleapi.com/
REDCIRCLE_API_KEY=

# Home Depot product data — https://docs.trajectdata.com/bigboxapi
BIGBOX_API_KEY=

# Lowe's product data — https://app.backyardapi.com/
BACKYARD_API_KEY=

# eBay product & sold-price data — https://docs.trajectdata.com/countdownapi
COUNTDOWN_API_KEY=

# Google Shopping — use ONE of the three below (SerpWow preferred)
# SerpWow:    https://serpwow.com/
SERPWOW_API_KEY=
# Scale SERP: https://scaleserp.com/
SCALESERP_API_KEY=
# Value SERP: https://valueserp.com/
VALUESERP_API_KEY=


# ── eBay Developer Keys ───────────────────────────────────────────────────────
# Get at: https://developer.ebay.com/
# Use SANDBOX keys for testing, PRODUCTION keys for live listings.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_TOKEN=
EBAY_ENVIRONMENT=sandbox


# ── LLM / AI (optional — for future AI product analysis agent) ────────────────
# Pick ONE provider. The system uses the first key it finds, in this order:
#
# 1. GROQ — FREE tier (rate-limited). Best for fast inference.
#    Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
#    Sign up: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#
# 2. OpenRouter — pay-per-use, very cheap. Access to 200+ models.
#    Free models available (e.g. mistralai/mistral-7b-instruct:free)
#    Sign up: https://openrouter.ai/keys
#    Pricing: https://openrouter.ai/models
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
#
# 3. Google Gemini Flash — FREE tier (generous limits).
#    Models: gemini-2.0-flash, gemini-1.5-flash
#    Sign up: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
